+	for (; node; node = rb_next(node)) {
+	    mnt = node_to_mount(node);
+		if (mnt->mnt_id == DEFAULT_KSU_MNT_ID) {
+			continue;
+		}
+		WRITE_ONCE(mnt->mnt.susfs_mnt_id_backup, READ_ONCE(mnt->mnt_id));
+		WRITE_ONCE(mnt->mnt_id, first_mnt_id++);
+	}
+
+out_put_mnt_ns:
+	put_mnt_ns(mnt_ns);
+}
+#endif
